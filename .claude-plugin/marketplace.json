{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "RossLabs-claude-plugins",
  "description": "Developer productivity plugins for Claude Code",
  "owner": {
    "name": "Tyrone Ross",
    "email": "tyrone@rosslabs.ai"
  },
  "plugins": [
    {
      "name": "bookmark",
      "description": "Session context continuity — auto-save and restore context across compactions and terminal closures",
      "version": "0.3.2",
      "author": { "name": "Tyrone Ross" },
      "source": {
        "source": "npm",
        "package": "@tyroneross/bookmark",
        "version": "^0.3.2"
      },
      "repository": "https://github.com/tyroneross/bookmark",
      "category": "developer-tools",
      "keywords": ["context", "snapshots", "session-continuity"]
    },
    {
      "name": "claude-code-debugger",
      "description": "Debugging memory — learn from past bugs with verdict-based retrieval and pattern extraction",
      "version": "1.7.0",
      "author": { "name": "Tyrone Ross" },
      "source": {
        "source": "npm",
        "package": "@tyroneross/claude-code-debugger",
        "version": "^1.7.0"
      },
      "repository": "https://github.com/tyroneross/claude-code-debugger",
      "category": "developer-tools",
      "keywords": ["debugging", "memory", "incident-tracking"]
    },
    {
      "name": "ibr",
      "description": "UI validation — verify implementations match intent with live page scanning and visual regression",
      "version": "0.7.0",
      "author": { "name": "Tyrone Ross" },
      "source": {
        "source": "npm",
        "package": "@tyroneross/interface-built-right",
        "version": "^0.7.0"
      },
      "repository": "https://github.com/tyroneross/interface-built-right",
      "category": "developer-tools",
      "keywords": ["ui", "validation", "visual-regression"]
    },
    {
      "name": "navgator",
      "description": "Architecture tracking — map dependencies, analyze impact, and visualize your stack",
      "version": "0.6.1",
      "author": { "name": "Tyrone Ross" },
      "source": {
        "source": "npm",
        "package": "@tyroneross/navgator",
        "version": "^0.6.1"
      },
      "repository": "https://github.com/tyroneross/NavGator",
      "category": "developer-tools",
      "keywords": ["architecture", "dependencies", "impact-analysis"]
    },
    {
      "name": "showcase",
      "description": "Dev asset capture — screenshots and video clips during development for blog/website content",
      "version": "0.1.0",
      "author": { "name": "Tyrone Ross" },
      "source": {
        "source": "npm",
        "package": "@tyroneross/showcase",
        "version": "^0.1.0"
      },
      "repository": "https://github.com/tyroneross/showcase",
      "category": "developer-tools",
      "keywords": ["screenshots", "video", "capture", "blog", "dev-assets"]
    }
  ]
}
